# ==========================================
# DeoBiz Manager - Git Ignore File
# ==========================================

# Environment variables (NEVER commit!)
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Uploads (optional - remove if you want to track logos)
uploads/*.png
uploads/*.jpg
uploads/*.jpeg
!uploads/.gitkeep

# Static files
static/icon-*.png
static/favicon.ico

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Production
instance/

# Render
.render/